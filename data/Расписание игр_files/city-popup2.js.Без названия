    var dropdown = $(popup).prev('.w-dropdown-toggle').trigger('tap')
    dropdown.trigger('tap')*/
    var popup = $(this).closest('.webant-header-region-confirm');
    $(popup).siblings('.w-dropdown-list').addClass('w--open')
