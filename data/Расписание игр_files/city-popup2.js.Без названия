$('.JS-SetCity').click(function(){
    $.get("/ajax/set-city", {"city" : $(this).data("city")}, function(response){
        if(response.success){
            $(".webantheader-region-confirm").remove();

        }
    });
    $(".webant-header-region-confirm").remove();
})

