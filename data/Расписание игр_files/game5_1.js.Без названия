function getTimeRemaining(endTime) {
    var t = Date.parse(endTime) - Date.parse(new Date());
    var seconds = Math.floor((t / 1000) % 60);
    var minutes = Math.floor((t / 1000 / 60) % 60);
    var hours = Math.floor((t / (1000 * 60 * 60)) % 24);
    var days = Math.floor(t / (1000 * 60 * 60 * 24));
    return {
        total: t,
        days: days,
        hours: hours,
        minutes: minutes,
        seconds: seconds,
    };
}
function resetFormButton() {
    var formButton = $("#form-button");
    const toPay = document.querySelector(".toPay");
    toPay.style.display = "none";
    formButton.attr("disabled", false);
    formButton.removeClass("button-disabled");
}

// Удаляет лишние поля сертификатов, кроме одной
function resetCertificates() {
    const certificates = document.querySelectorAll(".certificate");
    const wrapper = document.querySelector(".certificate__js");
    certificates[0].querySelector(".certificate__input__js").dataset.count = 0;
    if (certificates.length > 1)
        for (let i = 1; i < certificates.length; i++) {
            wrapper.removeChild(certificates[i]);
        }
}

function removeUnnecessaryCertificates() {
    const certificates = document.querySelectorAll(".certificate");
    const wrapper = document.querySelector(".certificate__js");
    for (let i = 1; i < certificates.length; i++) {
        const value = certificates[i].querySelector(
            ".certificate__input__js"
        ).value;
        if (!value) wrapper.removeChild(certificates[i]);
    }
}

