                        currentId = response.reservation;
                        // initializeClock();
                        $wrap.find("#qprecord-reservation").val(response.reservation);
                        $wrap.find("#reservation-p").show();
                    } else {
                        $wrap.find("#reservation-p").hide();
                    }

                    if (response.status == 1) {
                        if (
                            isOfflineGame &&
                            !isWithReservation &&
                            (isOnlyYandexPayment || isCashOrYandexPayment)
                        ) {
                            paymentType.style.display = "block";
                        } else {
                            paymentType.style.display = "none";
                        }
                        if (freeSlots < Math.round(response.max_players / 2)) {
                            paymentType.style.display = "none";
                        } else {
                            if (isCashOrYandexPayment) {
                                paymentType.style.display = "block";
                            }
                        }
                        $("#certificate").show();
                        $wrap.find("#qprecord-reserve").val(0);
                        $wrap.find(".text-warning").hide();
                        $wrap.find("#queue-warning").hide();
                        if (response.count < 9) {
                            selectPeoples.insertAdjacentHTML(
                                "afterend",
                                `
                <div id='free-place'>
                  На игре осталось место для одной команды до ${response.count} человек. 
                  Если вас больше, вы попадете в список резерва.
                </div>
              `
                            );
                        }
                    } else if (isReserve) {
                        paymentType.style.display = "none";
                        $wrap.find(".text-warning").show();
                        $(".text-warning").text(
                            "Внимание, вы регистрируетесь в резерв! Вам нужно дождаться уведомления от нас, что места появились и можно приходить."
                        );
                    } else if (response.status == 5 && !response.reservation) {
                        paymentType.style.display = "block";
                        $("#certificate").show();
                        $wrap.find("#qprecord-reserve").val(1);
                        $wrap.find(".text-warning").hide();
                        $wrap.find("#queue-warning").show();
                        $wrap.find("#reservation-p").hide();
                    } else {
                        paymentType.style.display = "block";
                        $wrap.find("#qprecord-reserve").val(1);
                        $("#certificate").hide();
                        $wrap.find("#queue-warning").hide();
                        $wrap.find(".text-warning").hide();
                    }

                    if (
                        (isOfflineGame && isOnlyYandexPayment && !isReserve) ||
                        (isOnlinePayment && !isReserve)
                    ) {
                        $(".cerf-radio").hide();
                        $(".firstRadio").attr("checked", false);
                        $(".secondRadio").attr("checked", true);
                        $(".payment-men").show();
                        $(".payment-undertext").hide();
                        $(".payment-title").html("Оплатить за");
                        toPay.style.display = "block";
                        toPay.innerHTML = `Сумма к оплате: <span class="span-link">${
                            price + currency
                        }</span>`;
                    }
                }

                $(".game-form-block.popup-form.w-form").attr("data-isOnline", response.game_type);

                if (response.game_type === 1) {
                    if (typeof paymentType !== "undefined")
                        paymentType.style.display = "none";
                        const calculator = document.querySelector(".price-calculator")
                        if (calculator) calculator.style.display = "none";
                    $wrap.find(".text-warning").show();

                    $(".text-warning").text(
                        "Подробную инструкцию, как играть, со всеми нужными ссылками вы получите за час до игры на указанные при регистрации эл.почту и телефон."
                    );
                }else {
                    const calculator = document.querySelector(".price-calculator")
                    if (calculator) calculator.style.display = "flex";
                }

                if (typeof window["fbq"] == "function") {
                    fbq("track", "InitiateCheckout");
                }
            });
        },
        getAddressFirstGame: function () {
            return $this.firstAddress;
        },
        setAddressFirstGame: function (firstAddress) {
            $this.firstAddress = firstAddress;
        },
    };
})();
