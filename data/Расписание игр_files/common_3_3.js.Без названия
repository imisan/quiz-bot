        if (typeCertificate) {
          $(".offline").click();
          show(typeCertificateBlock);
          if (deliveryBlock.contains(onlineDelivery)) {
            deliveryBlock.removeChild(onlineDelivery);
          }
          $(".kind-certificate-input-online").click();
          hide(paperBlock);
        } else {
          $(".type-game-input-online").click();
          if (deliveryBlock.contains(onlineDelivery)) {
            deliveryBlock.removeChild(onlineDelivery);
          }
          $(".online").click();
          hide(paperBlock);
          hide(electronicBlock);
        }

        function hide(block) {
          block.style.display = "none";
        }

        function show(block) {
          block.style.display = "inline";
        }

        function resetBlockInputs(block) {
          const inputs = block.querySelectorAll("input");
          inputs.forEach((input) => {
            if (input.checked) input.checked = false;
          });
        }

        var $wrap = $(".mfp-content");
        $wrap.find('textarea, input[type="text"]').val("");

        $wrap.find('button[type="submit"]').removeClass("disabled");
        $wrap.find('button[type="submit"]').removeAttr("disabled");
        resetFormButton();

        if ($(window).width() < 700) {
          this.st.focus = false;
        } else {
          this.st.focus = "#name";
        }
        mapWidth;
      },
    },
  });

