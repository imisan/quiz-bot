var loaded = new Object();

function loadPhoto(gameId) {
  if (!loaded[gameId]) {
    $.ajax({
      type: "get",
      url: "/ajax/load-photo",
      data: {
        id: gameId,
      },
      response: "text",
      async: true,
      success: function (data) {
        var parsedData = JSON.parse(data);
        divCore = $("#game_photos" + gameId);

        var layer = $(document.createElement("div"));
        layer.attr("class", "what-happens-photo-slider-item-layer");
        divCore.append(layer);

        var div1 = $(document.createElement("div"));
        div1.attr("class", "what-happens-photo-slider-item-info");
        divCore.append(div1);

        var div2 = $(document.createElement("div"));
        div1.append(div2);

        var div3 = $(document.createElement("div"));
        div3.attr("class", "what-happens-photo-slider-item-info-title");
        div3.text(parsedData.name);
        div2.append(div3);

        var div4 = $(document.createElement("div"));
        div4.attr("class", "what-happens-photo-slider-item-info-date");
        div4.text(parsedData.date);
        div2.append(div4);

        var div5 = $(document.createElement("div"));
        div2.append(div5);

        var link = $(document.createElement("a"));
        link.attr("href", parsedData.url);
        link.attr("target", "_blank");
        link.attr("class", "btn btn-warning");
        if (window.city_id == 'moscow') {
          link.attr(
              "onclick",
              "yaCounter35711540.reachGoal('visitedPhotoAlbum');ga('send', 'event', 'visitedPhotoAlbum', 'click');"
          );
        }

        link.text(parsedData.text);
        div5.append(link);

        setSliderHeight();

        loaded[gameId] = true;
      },
    });
  }
}

function setSliderHeight() {
  const imageHeight = $(
    ".what-happens-photo-slider .slick-active img"
  ).height();
  $(".what-happens-photo-slider .slick-list").height(imageHeight);
}
