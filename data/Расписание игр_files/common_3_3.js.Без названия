      e.preventDefault();
      $(".header-region").toggleClass("header-region-open");
      $(".total-city").toggleClass("total-city-open");
    } else {
      if (e.target.tagName != "A" && e.target.tagName != "a") {
        $(".header-region").removeClass("header-region-open");
        $(".total-city").removeClass("total-city-open");
      }
