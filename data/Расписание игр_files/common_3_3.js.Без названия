function initMap(gameId) {
  $(".techtext-halfwhite a").click(function (e) {
    e.preventDefault();
  });
  $(" .techtext-halfwhite a").on("click", function (e) {
    $.magnificPopup.close();
    $(this).magnificPopup("open");
  });
  $(".techtext-halfwhite a").magnificPopup({
    closeOnBgClick: false,
    type: "ajax",
    ajax: {
      settings: {
        method: "get",
        url: "/ajax/get-map-game",
        data: {
          id: gameId,
        },
      },
    },
    mainClass: "mfp-fade mfp-map",
    callbacks: {
      parseAjax: function (mfpResponse) {},
      ajaxContentAdded: function () {
        if (refreshIntervalId != null) {
          clearInterval(refreshIntervalId);
        }
        var address = $(".mfp-wrap").find(".hidden-address").val();
        // $(this.content).find('.mfp-close').appendTo($('.mfp-close').parent().parent());
        init();

        function init() {
          if ($("#maps").length) {
            if ($("#maps").attr("data-type") == "google") {
              geocoder = new google.maps.Geocoder();
              var latlng = new google.maps.LatLng(39.305, -76.617);
              map = new google.maps.Map(document.getElementById("maps"), {
                center: latlng,
                zoom: 14,
              });
              google.maps.event.addListenerOnce(map, "idle", function () {
                geocoder.geocode(
                  {
                    address: address,
                  },
                  function (results, status) {
                    if (status == "OK") {
                      map.setCenter(results[0].geometry.location);
                      var marker = new google.maps.Marker({
                        map: map,
                        position: results[0].geometry.location,
                      });
                    }
                  }
                );
              });
            } else {
              myMap = new ymaps.Map("maps", {
                center: [55.762166, 37.613063],
                zoom: 14,
              });

              // myMap.behaviors.disable('drag');
              var geocoder = ymaps.geocode(address);
              geocoder.then(function (res) {
                placeMark = new ymaps.Placemark(
                  res.geoObjects.get(0).geometry.getCoordinates(),
                  {
                    hintContent: address,
                    balloonContent: address,
                  }
                );
                myMap.geoObjects.add(placeMark);
                myMap.panTo(res.geoObjects.get(0).geometry.getCoordinates(), {
                  flying: true,
                });
              });
              // myMap.behaviors.disable('scrollZoom');
            }
          }
        }
      },
    },
  });
}

